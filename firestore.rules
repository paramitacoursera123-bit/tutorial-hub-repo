rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin users collection - only admins (OAuth users) can access
    match /adminUsers/{userId} {
      // Users can read/write their own admin profile
      allow read, write: if request.auth.uid == userId;
      // Admins can read all admin profiles
      allow read: if request.auth.uid != null && 
                     exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }
    
    // Regular users collection - only regular users can access
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if request.auth.uid == userId;
      // Admins cannot access regular user profiles
    }
    
    // Tutorials collection - readable by all, writable by admins only
    match /tutorials/{tutorialId} {
      // Everyone can read tutorials
      allow read: if true;
      // Only authenticated admins can create/update/delete
      allow create, update, delete: if request.auth.uid != null && 
                                       exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }
    
    // Tutorial categories - readable by all
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth.uid != null && 
                      exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }
    
    // Default deny for any other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
